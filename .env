# .env 文件内容示例

# 应用配置
DEBUG=True
PORT=8000

# 阿里 DashScope (Qwen) API Key
LLM_PROVIDER=dashscope
LLM_API_KEY=sk-2ea33be7c2604c3c8fc17aedfb7d8145

# 如果使用智谱 GLM
# LLM_PROVIDER=zhipu
# LLM_API_KEY=xxxxxxxxxxxxxxxx

# 如果使用本地部署的 Qwen-72B (通过 vLLM 或 Ollama)
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL_NAME=qwen-72b-chat

# 向量库配置
VECTOR_DB_TYPE=chroma
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# 密钥
SECRET_KEY=super-secret-key-for-session